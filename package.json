{
  "name": "pornwrld",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently -k \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --config client/vite.config.js",
    "dev:server": "node server.js",
    "build": "npm run build:client",
    "build:client": "vite build --config client/vite.config.js",
    "serve": "npm run build && node server.js",
    "db:schema": "psql \"$DATABASE_URL\" -f database/schema.sql",
    "db:migrate": "psql \"$DATABASE_URL\" -f database/migrations/001_platform_analytics.sql && psql \"$DATABASE_URL\" -f database/migrations/002_phone_and_indexes.sql && psql \"$DATABASE_URL\" -f database/migrations/004_media_storage_path_index.sql && psql \"$DATABASE_URL\" -f database/migrations/005_media_like_dedupe.sql && psql \"$DATABASE_URL\" -f database/migrations/006_backfill_media_likes_from_events.sql && psql \"$DATABASE_URL\" -f database/migrations/007_referral_program.sql && psql \"$DATABASE_URL\" -f database/migrations/008_referral_visits.sql && psql \"$DATABASE_URL\" -f database/migrations/009_catalog_precalc.sql",
    "db:migrate:referrals": "psql \"$DATABASE_URL\" -f database/migrations/007_referral_program.sql && psql \"$DATABASE_URL\" -f database/migrations/008_referral_visits.sql",
    "db:reset-seeded-media-metrics": "psql \"$DATABASE_URL\" -f database/migrations/003_reset_media_engagement.sql",
    "db:backfill-referrals": "node scripts/backfill-referral-codes.mjs",
    "r2:login": "wrangler login",
    "r2:whoami": "wrangler whoami",
    "r2:bucket-info": "wrangler r2 bucket info leakwrld",
    "r2:create-folders": "node scripts/r2-create-creator-folders.mjs",
    "r2:create-folders:dry": "node scripts/r2-create-creator-folders.mjs --dry-run",
    "r2:sync": "node scripts/r2-sync-creator-folders.mjs",
    "r2:sync:dry": "node scripts/r2-sync-creator-folders.mjs --dry-run",
    "r2:verify": "node scripts/r2-verify-creator-folders.mjs",
    "r2:count": "node scripts/r2-count-objects.mjs",
    "r2:rename-prefixes": "node scripts/r2-rename-video-prefixes.mjs",
    "r2:rename-prefixes:dry": "node scripts/r2-rename-video-prefixes.mjs --dry-run",
    "media:sync": "node scripts/r2-build-media-manifests.mjs",
    "media:sync:slug": "node scripts/r2-build-media-manifests.mjs --slug=",
    "thumbs:convert": "node scripts/convert-public-thumbnails-to-webp.mjs",
    "thumbs:convert:force": "node scripts/convert-public-thumbnails-to-webp.mjs --force",
    "media:thumbs:cache": "node scripts/media-thumb-cache.mjs",
    "media:thumbs:cache:force": "node scripts/media-thumb-cache.mjs --force",
    "catalog:rebuild": "node scripts/catalog-rebuild.mjs",
    "catalog:rebuild:force": "node scripts/catalog-rebuild.mjs --force",
    "media:pipeline": "node scripts/r2-media-pipeline.mjs",
    "media:transcode:hls": "node scripts/media-transcode-hls.mjs",
    "media:pipeline:dry": "node scripts/r2-media-pipeline.mjs --dry-run",
    "worker:dev": "wrangler dev --config worker/wrangler.jsonc",
    "worker:deploy": "wrangler deploy --config worker/wrangler.jsonc"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "geoip-lite": "^2.0.2",
    "hls.js": "^1.6.15",
    "lucide-react": "^1.8.0",
    "pg": "^8.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.2.4",
    "sharp": "^0.34.5",
    "vite": "^5.4.11",
    "wrangler": "^4.90.0"
  }
}
