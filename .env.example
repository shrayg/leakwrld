# Copy to `.env` for local development. On Fly.io, set the same keys with:
#   fly secrets set KEY1=value1 KEY2=value2 ...
# Never commit `.env`.

# --- Public URL (cookies, redirects, canonical) ---
TBW_PUBLIC_ORIGIN=https://your-domain.example

# --- Cloudflare R2 (media library; required for /api/list + /media) ---
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET_RAW=
# Optional; defaults match pornwrld/videos layout
# CLOUDFLARE_R2_ROOT_PREFIX=pornwrld
# CLOUDFLARE_R2_VIDEOS_PREFIX=pornwrld/videos
# CLOUDFLARE_R2_ASSETS_PREFIX=pornwrld/assets
# CLOUDFLARE_R2_CUSTOM_DOMAIN=
# Write JSON state blobs to R2 (default off)
# R2_DATA_STATE_ENABLED=0

# --- Security ---
TBW_PEPPER=

# --- Supabase (if used) ---
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# --- OAuth / checkout (enable what you use) ---
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# DISCORD_REDIRECT_URI=
# GOOGLE_CLIENT_ID=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# PATREON_WEBHOOK_SECRET=
