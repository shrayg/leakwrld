# Copy these lines into `.env` (never commit `.env`).
# Cloudflare → R2 → Overview → Manage R2 API Tokens → Create API token
# with permission to read/write objects on bucket `leakwrld`.
#
# Account ID: same value as `wrangler whoami` (Dashboard URL also shows it).

R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=

# Optional — defaults to leakwrld
# R2_BUCKET=leakwrld

# Optional — if omitted, endpoint is built from R2_ACCOUNT_ID
# R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
